{
  "name": "therapy-scheduler-backend",
  "version": "1.0.0",
  "description": "Bidirectional sync backend for Therapy Scheduler with Outlook & Splose",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --config jest.config.js",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:all": "npm test && npm run test:integration",
    "migrate": "node migrate.js up",
    "migrate:status": "node migrate.js status"
  },
  "keywords": [
    "therapy",
    "scheduler",
    "outlook",
    "splose",
    "sync"
  ],
  "author": "Antony Xavier",
  "license": "MIT",
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^2.2.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "helmet": "^8.2.0",
    "moment": "^2.29.4",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.7.0",
    "pg": "^8.10.0",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20 <27",
    "npm": ">=10"
  }
}
