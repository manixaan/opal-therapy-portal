# ═══════════════════════════════════════════════════════════════════════════
#  Opal Therapy Scheduler — environment configuration
#
#  Copy to .env and fill in real values. NEVER commit .env.
#  Validation: env-validation.js warns in development and REFUSES to boot in
#  production/staging when critical values are missing or weak.
#  Per-variable behaviour is documented in handover/ENVIRONMENT_VARIABLES.md.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────────
# PORT: injected by Azure App Service in cloud environments. Local dev: 5001.
PORT=5001
# NODE_ENV: development | staging | production
# staging/production activate: strict env validation, strict OAuth state,
# secure cookies, strict CSRF, hidden error details, TLS cert verification.
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=therapy_scheduler
DB_USER=postgres
DB_PASSWORD=REPLACE_ME
# Integration tests ALWAYS run against ${DB_NAME}_test and refuse anything else.

# ── Sessions & token encryption (CRITICAL in production) ───────────────────
# ≥32 random chars. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_48_RANDOM_BYTES_HEX
# Exactly 64 hex chars (32 bytes) — AES-256-GCM for stored OAuth tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Missing in development ⇒ tokens stored in PLAINTEXT with a warning.
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS

# ── Microsoft OAuth (Azure App Registration) ────────────────────────────────
MICROSOFT_CLIENT_ID=REPLACE_ME
MICROSOFT_CLIENT_SECRET=REPLACE_ME
# Must EXACTLY match a redirect URI configured on the app registration.
MICROSOFT_REDIRECT_URI=http://localhost:5001/auth/oauth/callback
# Azure directory (tenant). Unset ⇒ falls back to the development tenant.
MICROSOFT_TENANT_ID=REPLACE_WITH_TENANT_GUID

# ── Splose ──────────────────────────────────────────────────────────────────
SPLOSE_API_KEY=REPLACE_ME
SPLOSE_BASE_URL=https://api.splose.com

# ── Google Maps (travel time, geocoding, Places) ───────────────────────────
# Key needs: Routes API, Places API (New), Geocoding API, Maps JavaScript API.
# Missing ⇒ /api/maps/* return 503 and travel features degrade gracefully.
GOOGLE_MAPS_API_KEY=REPLACE_ME

# ── Email (SMTP) ────────────────────────────────────────────────────────────
# Unset in development ⇒ verification/invite/reset links are printed to the
# server console instead of being emailed (safe local workflow).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Opal Therapy <noreply@example.com>"
# Base URL used inside emailed links (verify/reset/invite).
APP_BASE_URL=http://localhost:5001

# ── Registration allowlist ──────────────────────────────────────────────────
# Read at process start (restart after changing). A fresh deployment MUST set
# ALLOWED_EMAILS to the first owner's address or nobody can ever register.
ALLOWED_DOMAINS=
ALLOWED_EMAILS=

# ── CORS / CSRF origin allowlist ────────────────────────────────────────────
# Comma-separated. Production must list the real portal origin.
ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001

# ── Outlook webhooks (real-time sync; needs a public HTTPS URL) ────────────
# Leave blank on localhost — 90-second polling covers sync. When set,
# WEBHOOK_CLIENT_STATE becomes REQUIRED and must not be the historical default.
WEBHOOK_BASE_URL=
WEBHOOK_CLIENT_STATE=

# ── Sync deletion-safety thresholds (Phase 3 data-loss controls) ───────────
# Max events one automatic sync cycle may delete, and max % of linked local
# events. Exceeding either blocks the batch, audits, and notifies owners.
SYNC_MAX_AUTO_DELETE=25
SYNC_MAX_DELETE_PERCENT=30

# ── Document storage backend (Phase 7) ─────────────────────────────────────
# db    (default) — file bytes stay base64 in Postgres (pilot behaviour)
# local           — files under DOCUMENT_STORAGE_PATH (dev/self-host)
# blob            — private Azure Blob Storage (staging/production target;
#                   requires @azure/storage-blob installed and the AZURE_* vars)
# Downloads are ONLY served through the authenticated
# GET /api/profile/documents/:id/download route — never public URLs.
DOCUMENT_STORAGE_BACKEND=db
DOCUMENT_STORAGE_PATH=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=employee-documents

# ── Migration safety ────────────────────────────────────────────────────────
# `npm run migrate` refuses to run when NODE_ENV=production unless the deploy
# pipeline sets this to true (or a deliberate manual run passes --yes).
MIGRATE_ALLOW_PRODUCTION=

# ── Observability (Phase 8) ─────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error (default: info in production, debug otherwise)
# Application Insights activates ONLY when the connection string is set AND the
# applicationinsights SDK is installed (deploy pipeline does this — not needed
# locally). Telemetry is redacted before leaving the process.
LOG_LEVEL=
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── Database TLS (Azure) ────────────────────────────────────────────────────
# Azure Database for PostgreSQL requires TLS — set true in staging/production.
# Leave unset for local plaintext development connections.
DB_SSL=
